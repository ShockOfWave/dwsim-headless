<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>XMLSerializer</RootNamespace>
    <AssemblyName>DWSIM.XMLSerializer</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <!-- Suppress common VB warnings that were suppressed in the original project -->
    <NoWarn>42016,41999,42017,42018,42019,42032,42036,42020,42021,42022</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- OxyPlot.Core: chart library for OxyColor serialization support -->
    <PackageReference Include="OxyPlot.Core" Version="2.0.0" />
    <!-- SkiaSharp: graphics library for SKColor serialization support -->
    <PackageReference Include="SkiaSharp" Version="2.88.9" />
    <!-- System.Drawing.Common: replaces System.Drawing framework reference -->
    <PackageReference Include="System.Drawing.Common" Version="8.0.10" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DWSIM.Interfaces\DWSIM.Interfaces.vbproj" />
  </ItemGroup>

  <!-- Exclude the old My Project auto-generated files that are not needed in SDK-style -->
  <ItemGroup>
    <Compile Remove="My Project\Application.Designer.vb" />
    <Compile Remove="My Project\Resources.Designer.vb" />
    <Compile Remove="My Project\Settings.Designer.vb" />
  </ItemGroup>

  <!--
    References REMOVED (built-in on .NET 8.0):
      - System.Buffers
      - System.Memory
      - System.Numerics.Vectors
      - System.Runtime.CompilerServices.Unsafe

    Reference CHANGES:
      - OxyPlot.Core: 2.0.0-unstable1035 -> 2.2.0
      - SkiaSharp: 1.68.2.1 -> 2.88.9 (API compatible for SKColor usage)
      - System.Drawing -> System.Drawing.Common 8.0.10 (NuGet package)
  -->

</Project>
