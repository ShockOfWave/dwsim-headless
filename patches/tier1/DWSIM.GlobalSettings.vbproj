<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>DWSIM.GlobalSettings</RootNamespace>
    <AssemblyName>DWSIM.GlobalSettings</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <DefineConstants>HEADLESS</DefineConstants>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <!-- Suppress common VB warnings that were suppressed in the original project -->
    <NoWarn>42016,41999,42017,42018,42019,42032,42036,42020,42021,42022</NoWarn>
    <MyType>Empty</MyType>
  </PropertyGroup>

  <ItemGroup>
    <!-- Nini: INI configuration library (nini-core targets net6.0+/netstandard2.1) -->
    <PackageReference Include="nini-core" Version="0.9.2.16" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DWSIM.Logging\DWSIM.Logging.csproj" />
  </ItemGroup>

  <!-- Exclude the old My Project auto-generated files that are not needed in SDK-style -->
  <ItemGroup>
    <Compile Remove="My Project\Application.Designer.vb" />
    <Compile Remove="My Project\Resources.Designer.vb" />
    <Compile Remove="My Project\Settings.Designer.vb" />
  </ItemGroup>

  <!--
    References REMOVED for headless build (no GPU, no Python embedding):
      - Cudafy.NET        (GPU computing, not available for .NET 8)
      - Python.Runtime     (pythonnet, not needed for headless server)
      - System.Runtime.InteropServices.RuntimeInformation (built-in on .NET 8)
      - Microsoft.CSharp  (built-in on .NET 8)
      - System.Reflection.Emit (built-in on .NET 8)

    Source code guarded with #If Not HEADLESS for Cudafy/Python.Runtime usage.
  -->

</Project>
