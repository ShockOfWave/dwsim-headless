<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>DWSIM.Inspector</RootNamespace>
    <AssemblyName>DWSIM.Inspector</AssemblyName>
    <OutputType>Library</OutputType>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <NoWarn>42016,41999,42017,42018,42019,42032,42036,42020,42021,42022</NoWarn>
    <DefineConstants>HEADLESS</DefineConstants>
  </PropertyGroup>

  <!-- Only include Inspector.vb (data structures + report logic) -->
  <!-- Exclude all WinForms windows and Eto UI windows -->
  <ItemGroup>
    <Compile Remove="Loading.vb" />
    <Compile Remove="Loading.Designer.vb" />
    <Compile Remove="Window.vb" />
    <Compile Remove="Window.designer.vb" />
    <Compile Remove="Window2.vb" />
    <Compile Remove="Window2.designer.vb" />
    <Compile Remove="Window_Eto.vb" />
    <Compile Remove="Window2_Eto.vb" />
    <!-- Exclude legacy My Project auto-generated files -->
    <Compile Remove="My Project\**" />
  </ItemGroup>

  <!-- Exclude embedded resources for WinForms forms -->
  <ItemGroup>
    <EmbeddedResource Remove="Loading.resx" />
    <EmbeddedResource Remove="Window.resx" />
    <EmbeddedResource Remove="Window2.resx" />
    <EmbeddedResource Remove="My Project\**" />
  </ItemGroup>

  <!-- NuGet packages -->
  <ItemGroup>
    <PackageReference Include="HtmlAgilityPack" Version="1.11.70" />
  </ItemGroup>

  <!-- Project references -->
  <!-- Removed: DockPanel (WinForms-only) -->
  <!-- Removed: ExtensionMethods.Eto (only used by Window_Eto.vb, Window2_Eto.vb) -->
  <!-- Removed: SharedClassesCSharp (only used by Window.vb for FilePicker) -->
  <ItemGroup>
    <ProjectReference Include="..\DWSIM.ExtensionMethods\DWSIM.ExtensionMethods.vbproj" />
    <ProjectReference Include="..\DWSIM.GlobalSettings\DWSIM.GlobalSettings.vbproj" />
    <ProjectReference Include="..\DWSIM.Interfaces\DWSIM.Interfaces.vbproj" />
  </ItemGroup>

</Project>
